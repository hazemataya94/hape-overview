# Logging
HAPE_LOG_LEVEL=DEBUG # optional; one of DEBUG, INFO, WARNING, ERROR, CRITICAL
HAPE_ENABLE_LOG_FILE=0 # optional; 0/1 or false/true
HAPE_LOG_FILE="/path/to/hape.log" # optional; used when HAPE_ENABLE_LOG_FILE is on

# Exporter
HAPE_EXPORTER_HOST="0.0.0.0" # optional; default bind host for exporter
HAPE_EXPORTER_PORT=9117 # optional; default exporter port
HAPE_EXPORTER_REFRESH_SECONDS=300 # optional; refresh interval in seconds

# EKS deployment cost exporter
HAPE_EDC_KUBE_CONTEXT="" # optional; if empty, active kube context is used
HAPE_EDC_AWS_PROFILE="" # optional; if empty, default boto3 profile resolution is used
HAPE_EDC_IGNORED_NAMESPACES="kube-system,kube-node-lease,kube-public,local-path-storage" # optional; comma-separated namespaces to ignore

# Kube agent
HAPE_KUBE_AGENT_PROMETHEUS_URL="http://localhost:9090" # optional; Prometheus API base URL
HAPE_KUBE_AGENT_GRAFANA_URL="http://localhost:3000" # optional; Grafana API base URL
HAPE_KUBE_AGENT_ALERTMANAGER_URL="http://localhost:9093" # optional; Alertmanager API base URL
HAPE_KUBE_AGENT_SQLITE_PATH="~/.hape/kube-agent.sqlite" # optional; local SQLite path for incident memory
HAPE_KUBE_AGENT_AI_ENABLED=false # optional; default AI behavior for kube-agent investigations
HAPE_KUBE_AGENT_AI_STALE_HOURS=6 # optional; rerun AI after this many hours
HAPE_KUBE_AGENT_RESTART_THRESHOLD=3 # optional; restart threshold used by deterministic checks
HAPE_KUBE_AGENT_POD_LOG_TAIL_LINES=200 # optional; default pod log tail size
HAPE_KUBE_AGENT_LOOKBACK_MINUTES=30 # optional; default evidence time window
HAPE_KUBE_AGENT_SLACK_CHANNEL="" # optional; default Slack channel for findings output

# GitLab
GITLAB_DOMAIN="your-gitlab-domain" # e.g. gitlab.com
GITLAB_TOKEN=""
GITLAB_DEFAULT_GROUP_ID=123 # must be an integer

# Kubernetes
KUBERNETES_CONTEXT="name-of-kube-context"

# Atlassian
ATLASSIAN_DOMAIN="company.atlassian.net"
ATLASSIAN_EMAIL="your.name@company.com"
ATLASSIAN_API_KEY="your-api-key"
CONFLUENCE_CHANGELOG_PARENT_PAGE_ID=123 # must be an integer
CONFLUENCE_CHANGELOG_ENTRY_PAGE_TEMPLATE_ID=123 # must be an integer
CONFLUENCE_TEST_PARENT_PAGE_ID=123 # must be an integer

# Grafana
GRAFANA_DOMAIN="grafana.example.com" # optional; used by grafana command when cli flag is not passed
GRAFANA_PORT=443 # optional; defaults to 443 if not set. 443 uses https, other ports use http
GRAFANA_TOKEN="" # optional; token auth for grafana command
GRAFANA_USERNAME="" # optional; basic auth username for grafana command
GRAFANA_PASSWORD="" # optional; basic auth password for grafana command
GRAFANA_DEPLOYMENTS_SUBPATH="monitor-system/grafana2/grafana2" # optional; used by grafana command when cli flag is not passed
